{
  "name": "@paramhub/app",
  "version": "0.0.1",
  "description": "Terminal UI for browsing and managing cloud parameter stores",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "paramhub": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paramhub/provider-aws-ssm": "workspace:*",
    "@paramhub/types": "workspace:*",
    "clipboardy": "^4.0.0",
    "diff": "^5.2.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0",
    "fuse.js": "^7.0.0",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/diff": "^5.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0",
    "tsup": "^8.0.0"
  }
}
