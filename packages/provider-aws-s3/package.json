{
  "name": "@paramhub/provider-aws-s3",
  "version": "0.0.1",
  "description": "AWS S3 provider for paramhub",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "@paramhub/aws-common": "workspace:*",
    "@paramhub/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "vitest": "^3.1.0"
  }
}
