{
  "name": "@paramhub/aws-common",
  "version": "0.0.1",
  "description": "Shared AWS credential, error, and region helpers for paramhub providers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.700.0",
    "@smithy/shared-ini-file-loader": "^3.1.0",
    "@smithy/types": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "vitest": "^3.1.0"
  }
}
